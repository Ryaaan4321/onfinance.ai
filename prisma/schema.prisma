generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  password  String
  scenarios Scenario[]
}

model Regulation {
  id        String   @id @default(uuid())
  title     String
  authority String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rules     Rule[]

  @@index([authority])
}

model Rule {
  id            String     @id @default(uuid())
  regulationId  String
  description   String
  condition     String
  severity      Severity
  penaltyPerDay Float?
  maxPenalty    Float?
  regulation    Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  @@index([regulationId])
  @@index([severity])
}

model Scenario {
  id             String             @id @default(uuid())
  name           String
  description    String
  createdById    String
  createdAt      DateTime           @default(now())
  daysOverdue    Int
  breachedRuleId String
  createdBy      User               @relation(fields: [createdById], references: [id])
  results        SimulationResult[]

  @@index([createdById])
}

model SimulationResult {
  id         String   @id @default(uuid())
  scenarioId String
  violations Json
  riskScore  Float
  penalty    Float
  createdAt  DateTime @default(now())
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@index([riskScore])
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
